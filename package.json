{
  "packageManager": "pnpm@10.32.1",
  "name": "weareonhire",
  "version": "0.0.0",
  "description": "",
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier --write .",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "generate-jwk": "node ./scripts/generate-jwk.ts",
    "migrate:dev": "node ./scripts/migrate.ts --mode=dev",
    "migrate:prod": "node --env-file=.env ./scripts/migrate.ts --mode=prod",
    "backfill:dev": "node ./scripts/contrail-backfill.ts",
    "backfill:prod": "node --env-file=.env ./scripts/contrail-backfill.ts",
    "lexicons:build": "lex build --out src/lib/lexicons --clear",
    "pglite:server": "pglite-server --db=./.pgdata --port=5432 --max-connections=10 --debug=1"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-svelte"
    ]
  },
  "engines": {
    "node": "24"
  },
  "dependencies": {
    "@atcute/jetstream": "^2.0.0",
    "@atmo-dev/contrail": "^0.6.0",
    "@atproto/api": "^0.19.18",
    "@atproto/lex": "^0.0.26",
    "@atproto/oauth-client-node": "^0.3.17",
    "@electric-sql/pglite": "^0.4.5",
    "@google/genai": "^2.0.1",
    "cookie-signature": "^1.2.2",
    "dialog-closedby-polyfill": "^1.3.0",
    "i18n-iso-countries": "^7.14.0",
    "invokers-polyfill": "^1.0.3",
    "keyux": "^0.11.5",
    "kysely": "^0.29.0",
    "nanoid": "^5.1.11",
    "pg": "^8.20.0",
    "valibot": "^1.4.0"
  },
  "devDependencies": {
    "@electric-sql/pglite-socket": "^0.1.5",
    "@netlify/functions": "^5.2.0",
    "@sveltejs/adapter-netlify": "^6.0.4",
    "@sveltejs/kit": "^2.59.1",
    "@types/cookie-signature": "^1.1.2",
    "@types/node": "^25.6.2",
    "@types/pg": "^8.20.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "typescript": "^6.0.3",
    "typescript-svelte-plugin": "^0.3.52",
    "vite": "^8.0.12",
    "vitest": "^4.1.5"
  }
}
